{
  "name": "hedge-fund-13f-tracker",
  "version": "1.0.0",
  "description": "Monitor institutional investor holdings via SEC 13F filings",
  "repository": "https://github.com/josecookai/hedge-fund-13f-tracker",
  "author": "josecookai",
  "license": "MIT",
  "type": "skill",
  "keywords": [
    "13f",
    "hedge-fund",
    "institutional-investors",
    "sec-edgar",
    "whalewisdom",
    "smart-money",
    "finance",
    "trading"
  ],
  "entry_points": {
    "cli": "scripts/hf-tracker",
    "dashboard": "scripts/dashboard.py",
    "bot": "scripts/telegram_bot.py"
  },
  "commands": [
    "hf-tracker list-funds",
    "hf-tracker holdings --fund <fund-id>",
    "hf-tracker compare --fund <fund-id> -q1 <Q1> -q2 <Q2>",
    "hf-tracker consensus --ticker <TICKER>"
  ],
  "requirements": [
    "python>=3.10",
    "sqlite3"
  ],
  "install": "pip install -r requirements.txt && python scripts/init_db.py",
  "documentation": "https://github.com/josecookai/hedge-fund-13f-tracker#readme"
}